:0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"19"},{"filePath":"35","messages":"36","suppressedMessages":"37","errorCount":0,"fatalErrorCount":0,"warningCount":2,"fixableErrorCount":0,"fixableWarningCount":0,"source":"38"},"/Users/zackyviriot/bug-tracker/src/index.js",[],[],[],"/Users/zackyviriot/bug-tracker/src/App.js",[],[],"/Users/zackyviriot/bug-tracker/src/Components/NavbarMenu/NavbarMenu.js",[],[],"/Users/zackyviriot/bug-tracker/src/Components/SubmitTicket/SubmitTicket.js",[],[],"/Users/zackyviriot/bug-tracker/src/Components/TicketDashBaord/TicketDashBoard.js",[],[],"/Users/zackyviriot/bug-tracker/src/Components/TicketRecord/TicketRecord.js",[],[],"/Users/zackyviriot/bug-tracker/src/Components/SubmitTicket/TicketForm/TicketForm.js",["39","40"],[],"import { React, useState, useEffect } from 'react'\nimport { render } from 'react-dom';\nimport 'bootstrap/dist/css/bootstrap.min.css'\nimport { Button, Form, Container } from 'react-bootstrap';\n\n\n\n\n\nexport const TicketForm = () => {\n    const [form, setForm] = useState({})\n    const [errors, setErrors] = useState({})\n\n    const setField = (field, value) => {\n        setForm({\n            ...form,\n            [field]: value\n        })\n\n        if(!!errors[field])\n        setErrors({\n            ...errors,\n            [field]:null\n        })\n\n    }\n    const handleSubmit = e => {\n        e.preventDefault()\n        console.log(form)\n    }\n\n\n\n    return (\n        <Container className='TicketContainerForm'>\n            <Form>\n                <Form.Group controlId='form.Title'>\n                    <Form.Label>Ticket Title</Form.Label>\n                    <Form.Control \n                        type='text'  \n                        isInvalid={!!errors.TicketTitle} \n                        value = {form.TicketTitle} \n                        onChange = {(e) => setField('TicketTitle',e.target.value)} \n                    />\n                    <Form.Control.Feedback type = 'invalid'>\n                        {errors.TicketTitle}\n                    </Form.Control.Feedback>\n                </Form.Group>\n                <Form.Group controlId='form.Description'>\n                    <Form.Label>Ticket Description</Form.Label>\n                    <Form.Control \n                        as='textarea' \n                        placeholder='Please describe your ticket' \n                        rows={3}\n                        isInvalid = {!!errors.TicketDescription}\n                        value = {form.TicketDescription}\n                        onChange = {(e) => setField('TicketDescroption',e.target.value)}\n                      />\n                </Form.Group>\n                <Form.Group controlId='form.serverity' >\n                    <Form.Label>Ticket severity</Form.Label>\n                    <Form.Select aria-label=\"Default select example\" value = {form.ticketSeverity} onChange = {(e) => setField('TicketSevrity',e.target.value)}>\n                        <option>Open this select menu</option>\n                        <option value=\"1\">Low</option>\n                        <option value=\"2\">Medium</option>\n                        <option value=\"3\">High</option>\n                        <option value=\"4\">Urgent</option>\n                    </Form.Select>\n                </Form.Group>\n                <Form.Group controlId='form.date' >\n                    <Form.Label>Date Created</Form.Label>\n                    <Form.Control \n                        type='date' \n                        placeholder='Date Created for Ticket' \n                        className = {!!errors.location && 'red-border'}\n                        value = {form.TicketDate}\n                        onChangeCapture = {(selected) => {\n                            console.log(selected)\n                            setField('date',selected)\n                        }}\n                    />\n                </Form.Group>\n                <Button variant='dark' type='submit' className='mt-3' onClick = {handleSubmit}>Submit</Button>{' '}\n            </Form>\n        </Container>\n    )\n}",{"ruleId":"41","severity":1,"message":"42","line":1,"column":27,"nodeType":"43","messageId":"44","endLine":1,"endColumn":36},{"ruleId":"41","severity":1,"message":"45","line":2,"column":10,"nodeType":"43","messageId":"44","endLine":2,"endColumn":16},"no-unused-vars","'useEffect' is defined but never used.","Identifier","unusedVar","'render' is defined but never used."]